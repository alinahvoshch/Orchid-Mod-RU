Configs: {
	OrchidClientConfig: {
		DisplayName: Orchid Client Config
		Headers.General: General Header

		ShowClassTags: {
			Label: Show tags
			Tooltip: "{$Enables/Disables the display of class tags}"
		}

		UseOldGuardianHammerUi: {
			Label: Old Guardian Hammer UI
			Tooltip: Use the old Guardian Hammer UI (Paper Mario style)
		}

		SwapPaviseImputs: {
			Label: Swap Pavise Imputs
			Tooltip: Swap Left and Right click inputs for Guardian Pavises
		}

		SwapGauntletImputs: {
			Label: Swap Parry Items Imputs
			Tooltip: Swap Left and Right click inputs for Guardian Parry Items (Gauntlets, Quarterstaves, ...)
		}

		AltGuardianChargeSounds: {
			Label: Alternative Guardian Charge Sounds
			Tooltip: Replaces the Sound played when fully charging a guardian item
		}

		BlockCancelChain: {
			Label: Pavise Block Cancel Auto-re-use
			Tooltip: If possible, automatically starts blocking again when cancelling a block with right click
		}

		ShowModTags: {
			Label: Show Mod Tags
			Tooltip: "{$Enables/Disables the display of cross-content items tooltips (Load Crossmod-Content without required mods must be enabled in Orchid Server Config)}"
		}
	}

	OrchidServerConfig: {
		DisplayName: Orchid Server Config
		Headers.General: General Header

		LoadCrossmodContentWithoutRequiredMods: {
			Label: Load Crossmod-Content without required mods
			Tooltip: "{$Enables/Disables loading Crossmod-Content without required mods}"
		}
	}
}

