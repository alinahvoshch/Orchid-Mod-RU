NPCs: {
	BoundChemist.DisplayName: Связанный химик

	Chemist: {
		DisplayName: Химик
		
		Names: {
			1: Элоди
			2: Анник
			3: Саманта
			4: Амбрэ
			5: Мива
			6: Флорианна
			7: Джульета
			8: Хлоя
			9: Амандина
			10: Алисия
		}

		TownNPCMood: {
			Content: Клёвое место для проведения экспериментов!
			NoHome: Если бы только у меня было место для лаборатории...
			FarFromHome: Надеюсь, лаборатория у меня дома в порядке...
			LoveSpace:Химия в этом месте потрясающая! Понял?
			DislikeCrowded: Вокруг так много людей, это отвлекает меня.
			HateCrowded: Ну и как я должна эксперементировать в таком людном месте?
			LoveBiome: "{BiomeName} — хорешее место для поиска ингридиентов."
			LikeBiome: "{BiomeName} — замечательное место! Здесь так мново вещей, с которыми можно поиграть, в смысле, поэкспериментировать!"
			DislikeBiome: "{BiomeName} жаркая и сухая. Хорошо, что я запаслась игнридиентами до этого."
			HateBiome: "{BiomeName} напоминает мне о том, что я пережила до того, как была спасена тобой. Что за ужасный опыт..."
			LoveNPC: "{NPCName} знает так много раегентов! Она много мне помогает."
			LikeNPC: "{NPCName} крутой чувак, не думала, что ему нравится химия."
			DislikeNPC: Я очень надеюсь, что {NPCName} не взорвёт мою лабораторию снова...
			HateNPC: "{NPCName} продолжает доставать меня, прося создать новое оружие, почему бы ему просто не оставить меня в покое?"
			LikeNPC_Princess: Мне нравится {NPCName}.
			Princess_LovesNPC: Мне нравится {NPCName}.
		}
		
		UI: {
			RHint: Подсказка к реакции
			SHint: Специальная подсказка!
		}


		Dialogues: {
			1: Спасибо, ты избавил меня от тонны проблем, а ведь могло... Давай не будем об этом.
			2: Хочешь пожертвовать свою кровь на благо науки? Нет? Тогда пока.
			3: Конечно ты не можешь использовать обычные банки, когда занимаешься алхимией! Давай-ка сюда свои деньги!
			4: Эм, постой, ты хочешь взрыв устроить или что?
			5: НЕ СМЕЙ мне тут ничего пачкать! И меня не заботит, что я уже запачкала всё, что можно!
			6: То есть ты интересуешься алхимией И до сих пор не взорвался? Впечатляет.
			7: Всегда носи перчатки! Кстати, ты мои не видел?
			8: Знаешь, можно использовать центрифугу для удаления пятен! Ну, почти пятен.
			9: Ты можешь стать катализатором для науки! Или кучкой пепла. Расставляй приоритеты.
			10: Именно алхимия заставляет мир вращаться... так говорят современные научные теории.
			11: Предупреждение для твоей безопасности: не пей алхимические соединения просто так. Сперва мне нужно взять блокнот и ручку.
			12: Некоторые люди называют меня реакционером.
			13: Алхимия — возгоночная наука!
			14: Жизнь — всего лишь одна большая реакция!
			15: Жизнь после смерти — всего лишь одна большая реакция! Не знаю, почему луна вызывает её.
			16: Мне кажется или луна... сделана из аттарактита?!
			17: Есть такой научный метод... продолжай совершенствовать вещество, пока оно не перестанет взрываться!
			18: Вот твой ежедневный рецепт... прошу заметить, что он сам — не ингридиент.
			19: Держи, и постарайся не потерять руки из-за этой штуки.
			20: У меня не было времени испытать этот. Если не увижу тебя завтра, буду считать, что оно не сработало так, как я задумывала.
			21: И вот один совершенно точно правильно работающий бесплатный рецепт! Или же нет?
			22: Вот этот должен работать. Скорее всего. Возможно. Я бы не стала подвергать тебя опасности, не так ли?
			23: Если это бесплатно, то, скорее всего, подопытный — это ты, говоришь? Да не-е-е-е... эй, даже не думай испытывать это рядом со мной!
			24: Мне нужно время для того, чтобы придумать ещё парочку рецептов. Может убьёшь парочку плохишей, пока я думаю?
			25: Сверхознакомление с моими блестящими идеями может быть опасным для тебя, стажёр.
			26: Я уже дала тебе один сегодня, почему бы тебе не придумать свои собственные рецепты?
			27: На данный момент у меня нет ничего, что бы ты мог протестировать. Погоди, что ты только что сказал?
			28: Так как ты спраиваешь в первый раз, я продам тебе три подсказки по цене одной, а в придачу ещё и маленький подарок! А теперь я бы настоятельно рекомендовала тебе заполучить рукопись о секретных реакций...
			29: Вижу, ты нашёл немного светящихся грибов. А ты знал, что из них можно сплести неплохую ткань? Вот рецепт.
			30: О, лилии джунглей, я обожаю эти цветы! Ты хочешь заставить их цвести, не так ли? Вот решение.
		}

		Census.SpawnCondition: Можно найти связанно в главной шахте, расположенной в центре мира
	}

	Croupier: {
		DisplayName: Croupier

		TownNPCMood: {
			Content: Ey, that sure is a fine place to deal with.
			NoHome: Being homeless reminds me of darker times...
			FarFromHome: Chief, it's not that I don't like this place, but I'd like to go back?
			LoveSpace: If i knew i'd end up is such a cool corner, I'd have arrived earlier!
			DislikeCrowded: Neighbors are fine and all, but y'know, that's a bit much.
			HateCrowded: So many bystanders! Can't even ... play an honest game without being seen!
			LoveBiome: "{BiomeName} is perfect to keep pristine cards."
			LikeBiome: "{BiomeName} is chill, I'm down to stay."
			DislikeBiome: "{BiomeName} is fine with me, but my cards? Not much."
			HateBiome: The moisture in {BiomeName} air is ruining my cards!
			LoveNPC: "{NPCName} is an amazing buddy, we play every night around a nice beer!"
			LikeNPC: "{NPCName} is a cool girl. Chemistry reminds me of that one game..."
			DislikeNPC: I didn't believe it, but {NPCName} taught me that goblins really CAN'T play cards.
			HateNPC: "{NPCName} keeps pestering me about gambling, and blah, blah. why is he so nosy?"
			LikeNPC_Princess: I like {NPCName}.
			Princess_LovesNPC: I like {NPCName}.
		}

		Census.SpawnCondition: Have a gamber card ([i:8427][i:8409] etc.) in your deck
	}

	DownpourElemental.DisplayName: Downpour Elemental
